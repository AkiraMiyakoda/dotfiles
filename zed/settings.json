                },
                {
                    "paths": ["/home/akira/code/kodzuchi"],
                },
                {
                    "paths": ["/home/akira/code/mahjongsoul-electron"],
                },
                {
                    "paths": ["/home/akira/code/rust-utils"],
                },
                {
                    "paths": ["/home/akira/code/tombi"],
                },
                {
                    "paths": ["/home/akira/code/tombi-test"],
                },
                {
                    "paths": ["/home/akira/code/toml-test"],
                },
            ],
        },
    ],
    "ssh_connections": [
        {
            "host": "caesario",
            "username": "akira",
            "args": [],
            "projects": [
                {
                    "paths": ["/home/akira/code/wallclock"],
                },
            ],
        },
    ],
    "terminal": {
        "font_family": "UDEV Gothic NF",
        "font_weight": 400.0,
        "font_size": 14.0,
        "line_height": {
            "custom": 1.4,
        },
    },
    "telemetry": {
        "diagnostics": true,
        "metrics": true,
    },
    "minimap": {
        "max_width_columns": 140,
        "show": "always",
    },
    "file_types": {},
    "show_whitespaces": "all",
    "show_edit_predictions": true,
    "ensure_final_newline_on_save": true,
    "wrap_guides": [80, 120, 160],
    "base_keymap": "VSCode",
    "ui_font_size": 17,
    "theme": {
        "mode": "dark",
        "light": "Ayu Light",
        "dark": "Catppuccin Macchiato - No Italics",
    },
    "disable_ai": true,
