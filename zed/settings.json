// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
    "ui_font_family": "UDEV Gothic",
    "buffer_font_family": "UDEV Gothic",
    "buffer_font_size": 16,
    "buffer_font_weight": 400.0,
    "restore_on_startup": "last_workspace",
    "tab_size": 4,
    "prettier": {
        "allowed": true,
    },
    "icon_theme": "Catppuccin Macchiato",
    "text_rendering_mode": "platform_default",
    "indent_guides": {
        "background_coloring": "disabled",
        "coloring": "fixed",
    },
    "scrollbar": {
        "show": "auto",
        "selected_text": true,
        "cursors": true,
        "git_diff": true,
    },
    "cli_default_open_behavior": "existing_window",
    "languages": {
        "Rust": {
            "semantic_tokens": "combined",
            "formatter": {
                "language_server": {
                    "name": "rust-analyzer",
                },
            },
        },
        "TOML": {
            "formatter": { "language_server": { "name": "tombi" } },
        },
        "YAML": {
            "tab_size": 2,
        },
    },
    "lsp": {
        "rust-analyzer": {
            "initialization_options": {
                "rustfmt": {
                    "extraArgs": ["+nightly"],
                },
            },
        },
    },
    "toolbar": {
        "breadcrumbs": true,
    },
    "buffer_line_height": {
        "custom": 1.45,
    },
    "project_panel": {
        "bold_folder_labels": true,
        "file_icons": true,
        "folder_icons": true,
        "git_status": true,
        "git_status_indicator": true,
        "diagnostic_badges": true,
        "default_width": 240.0,
        "dock": "left",
    },
    "outline_panel": {
        "dock": "right",
    },
    "collaboration_panel": {
        "dock": "left",
    },
    "agent": {
        "dock": "right",
        "favorite_models": [],
        "model_parameters": [],
    },
    "git_panel": {
        "dock": "left",
    },
    "wsl_connections": [
        {
